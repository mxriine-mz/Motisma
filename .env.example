# Copy this file to ".env" and fill in the values.
# The real .env must NEVER be committed (it is in .gitignore).

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Application (client) ID — needed to register slash commands
CLIENT_ID=

# ID of the Pokemon GO - Pau community server (guild)
GUILD_ID=

# "Pending" role assigned to newcomers until a moderator validates them.
VERIFICATION_ROLE_ID=

# Member role ("Dresseur") granted once a newcomer is validated. Empty = none.
MEMBER_ROLE_ID=

# Optional: restrict the verification flow to a single channel (else any channel).
VERIFICATION_CHANNEL_ID=

# "Join to create" hub voice channel: joining it spawns a personal channel.
TEMP_VOICE_HUB_ID=
# Category where temp voice channels are created (empty = same category as the hub).
TEMP_VOICE_CATEGORY_ID=

# Category where /rdv creates its temporary meetup channels.
RDV_CATEGORY_ID=

# Channel where /rdv announces newly created meetups.
RDV_ANNOUNCE_CHANNEL_ID=

# Channel where a welcome message is posted once a newcomer is validated.
WELCOME_CHANNEL_ID=

# Staff log channel: audit embeds (who validated whom, suspicious photo, etc.).
# Empty = no log is posted.
LOG_CHANNEL_ID=

# Role whose members are listed as "ambassadeurs" in the /presentation embed.
AMBASSADOR_ROLE_ID=

# --- Database (Docker) ---
# Password for the PostgreSQL container. Used by docker-compose for both the
# db service and the bot's DATABASE_URL. Choose a strong value.
POSTGRES_PASSWORD=

# PostgreSQL connection string. In docker-compose it is injected automatically
# (postgres://rotom:<POSTGRES_PASSWORD>@db:5432/rotom). Only set it manually if
# you run the bot OUTSIDE Docker against your own database.
DATABASE_URL=

# --- Vision (optional) ---
# Google Gemini API key (free tier) — lets the bot read PoGo profile screenshots
# and auto-detect the trainer name on validation. Free key: https://aistudio.google.com/apikey
# Leave empty to disable.
GEMINI_API_KEY=

# Vision model (default: gemini-2.5-flash, free tier).
VISION_MODEL=

# --- Leveling (optional) ---
# Channel for level-up messages (else the channel where it happened).
LEVELUP_CHANNEL_ID=

# Reward roles by level: "10:roleId,20:roleId,30:roleId" (a role each 10 levels).
LEVEL_ROLES=

# --- Forum ❤️ ---
# Forum channel where the bot reacts ❤️ to posted images.
FORUM_HEART_CHANNEL_ID=

# --- Forum post keep-alive ---
# Forum posts (threads) whose "<#id>" mention is shown in an embed. The bot
# unarchives them on a schedule so they never render "#Inconnu" once Discord
# auto-archives them. Comma/space separated thread ids. Empty = off.
FORUM_KEEPALIVE_IDS=

# --- Status (presence) ---
# Custom status (the "bubble" line, no verb). Default: "/help • Pokémon GO Pau ⚡".
PRESENCE_TEXT=
# Status emoji before the custom status. Unicode ("🏃") or a custom server emoji
# as "name:id" (e.g. "roucoul:123456789012345678"). Empty for none.
PRESENCE_EMOJI=
# Rich-presence-style activity (the "Joue à …" line). Empty to disable.
# NOTE: bots usually show only ONE activity, so this may hide the custom status.
PRESENCE_GAME=
# Verb for PRESENCE_GAME: playing | watching | listening | competing.
PRESENCE_GAME_TYPE=
# Online state: online | idle | dnd | invisible. Default: online.
PRESENCE_STATUS=

# --- Pokémon GO team roles (optional) ---
# Detected from the level/XP colour on a profile screenshot and assigned
# automatically (exclusive) on verification or stats update. Leave empty to
# detect/store the team without assigning a Discord role.
TEAM_ROLE_MYSTIC=    # Sagesse (bleu)
TEAM_ROLE_VALOR=     # Bravoure (rouge)
TEAM_ROLE_INSTINCT=  # Intuition (jaune)

# --- Monthly PoGo classement (optional) ---
# Role synced with classement participation (assigned on /classement-pogo rejoindre).
# Leave empty to track opt-in in the database only (works without the role).
CLASSEMENT_ROLE_ID=
# Day of the month (1-28) the reminder DM is sent. Default: 1.
CLASSEMENT_REMINDER_DAY=
# Hour of day (0-23, server time) the reminder is sent. Default: 10.
CLASSEMENT_REMINDER_HOUR=
# Staff channel alerted when a submitted screenshot looks edited or the stats
# regress (anti-cheat). Empty = the refusal is only logged to the console.
CLASSEMENT_ADMIN_CHANNEL_ID=

# --- Language watch ---
# When a member swears, Motisma replies AND times them out for N seconds (0 to
# disable the timeout). Needs the bot to have "Moderate Members" + a higher role.
LANGUAGE_TIMEOUT_MILD=10
LANGUAGE_TIMEOUT_STRONG=30

# --- Web API (server/) ---
# Port for the POGO PAU web API (Discord login + stats leaderboard). 3100 by
# default to avoid clashing with other services already on the host.
PORT=3100

# Public origin of the website — used to redirect back after Discord login.
WEB_ORIGIN=https://pogo-pau.mxrine-mz.dev

# OAuth2 redirect URI. Must EXACTLY match a redirect registered in the Discord
# Developer Portal (OAuth2 > Redirects). Production and local dev each need their
# own registered entry:
#   prod: https://pogo-pau.mxrine-mz.dev/api/auth/callback
#   dev:  http://localhost:5173/api/auth/callback
OAUTH_REDIRECT_URI=https://pogo-pau.mxrine-mz.dev/api/auth/callback

# Discord OAuth2 client secret (Developer Portal > OAuth2). Server-side ONLY,
# never commit it. If it has ever been exposed, reset it in the portal first.
DISCORD_CLIENT_SECRET=

# Secret used to sign session cookies. Generate one: openssl rand -hex 32
SESSION_SECRET=

# Set to true in production (HTTPS) so session cookies are marked Secure.
COOKIE_SECURE=true

# Discord user IDs allowed to validate submitted stats (comma-separated).
ADMIN_DISCORD_IDS=
